# Next.js — copy to .env.local. Never commit .env.local.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
DJANGO_API_URL=http://localhost:8000/api
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8000
NEXT_PUBLIC_IMAGE_HOSTNAMES=localhost:9000,127.0.0.1:9000,localhost:8000,res.cloudinary.com

# Payment: demo (no Stripe key) | stripe
NEXT_PUBLIC_PAYMENT_PROVIDER=demo

# Stripe Test Mode (only when NEXT_PUBLIC_PAYMENT_PROVIDER=stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
