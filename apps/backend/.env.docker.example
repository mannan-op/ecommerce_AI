# Copy to apps/backend/.env before running docker compose up
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DATABASE_URL=postgres://ecommerce:ecommerce@db:5432/ecommerce
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ecommerce-media
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public URL for browser/Next.js (Django uses minio:9000 internally in Docker)
AWS_S3_CUSTOM_DOMAIN=localhost:9000/ecommerce-media
AWS_S3_URL_PROTOCOL=http:
AWS_S3_REGION_NAME=us-east-1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
DEFAULT_PAYMENT_PROVIDER=demo
PAYMENT_CURRENCY=usd
# demo | huggingface | fal | replicate | auto
DEFAULT_TRYON_PROVIDER=huggingface
HF_TOKEN=hf_your_token_here
TRYON_HF_SPACE=yisol/IDM-VTON
TRYON_HF_SPACE_URL=https://yisol-idm-vton.hf.space
TRYON_FALLBACK_TO_DEMO=False
TRYON_ABANDONMENT_ENABLED=True
TRYON_ABANDONMENT_SECONDS=86400
SITE_URL=http://localhost:3000
SITE_NAME=MAISON
THROTTLE_TRYON=60/hour
# Gmail SMTP — App Password: https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your.name@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your.name@gmail.com
