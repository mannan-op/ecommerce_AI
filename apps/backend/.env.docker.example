# Copy to apps/backend/.env before running docker compose up
SECRET_KEY=dev-only-secret-key-replace-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DATABASE_URL=postgres://ecommerce:ecommerce@db:5432/ecommerce
REDIS_URL=redis://redis:6379/0
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ecommerce-media
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public URL for browser/Next.js (Django uses minio:9000 internally in Docker)
AWS_S3_CUSTOM_DOMAIN=localhost:9000/ecommerce-media
AWS_S3_URL_PROTOCOL=http:
AWS_S3_REGION_NAME=us-east-1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
DEFAULT_PAYMENT_PROVIDER=demo
PAYMENT_CURRENCY=usd
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@ecommerce.local
SITE_NAME=E-Commerce AI
