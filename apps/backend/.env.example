# Django — copy to .env and fill in real values. Never commit .env.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
DATABASE_URL=postgres://ecommerce:ecommerce@localhost:5432/ecommerce

# Redis (Phase 2/3: caching, Celery broker, sessions)
REDIS_URL=redis://localhost:6379/0

# S3-compatible media storage (MinIO locally, AWS S3 / Cloudflare R2 in prod)
USE_S3=True
S3_PRIVATE_MEDIA=False
S3_PRESIGNED_URL_EXPIRY=3600
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ecommerce-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/ecommerce-media
AWS_S3_URL_PROTOCOL=http:
AWS_S3_REGION_NAME=us-east-1

# Checkout totals
SHIPPING_FLAT_RATE=9.99
FREE_SHIPPING_THRESHOLD=75.00
TAX_RATE=0.05
ESTIMATED_DELIVERY_DAYS=5

# Stripe (optional — leave empty when using demo mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# demo | stripe | payfast | jazzcash — server-side only (clients cannot override)
DEFAULT_PAYMENT_PROVIDER=demo
PAYMENT_CURRENCY=usd

DEFAULT_TRYON_PROVIDER=auto
TRYON_PREFER_FREE=True
HF_TOKEN=
TRYON_HF_SPACE=yisol/IDM-VTON
FAL_KEY=
TRYON_FAL_MODEL=fal-ai/fashn/tryon/v1.6
TRYON_FAL_MODE=balanced
REPLICATE_API_TOKEN=
TRYON_REPLICATE_MODEL=cuuupid/idm-vton
TRYON_SYNC_PROCESSING=False
TRYON_PHOTO_RETENTION_DAYS=30


NOTIFICATION_RETENTION_DAYS=90
# AI stylist chat (Groq — https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email — Gmail SMTP (App Password required: https://myaccount.google.com/apppasswords)
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your.name@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your.name@gmail.com
SITE_NAME=E-Commerce AI
SITE_URL=http://localhost:3000

# Try-on lead emails (customer recovery + staff alert)
TRYON_ABANDONMENT_ENABLED=True
TRYON_ABANDONMENT_SECONDS=86400

# CORS / CSRF (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Production hardening (when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SENTRY_DSN=
# LOG_LEVEL=INFO
