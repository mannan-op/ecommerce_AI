{
  "name": "ecommerce-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "turbo format",
    "schema": "npm run schema --workspace=@ecommerce/backend",
    "generate:types": "npm run schema && npm run generate --workspace=@ecommerce/types",
    "seed": "npm run seed --workspace=@ecommerce/backend"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
