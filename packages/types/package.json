{
  "name": "@ecommerce/types",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../../apps/backend/schema.yaml -o src/generated.ts",
    "build": "npm run generate && tsc",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.8.3"
  }
}
